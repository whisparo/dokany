{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "ES2020"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // ✅ ممتاز ومتوافق مع Next.js و Bun
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "bun-env.d.ts",     // ✅ ضفنا دي عشان Bun يتعرف على الـ Globals بتاعته
    "**/*.ts",
    "**/*.tsx",
    "src/**/*",         // ✅ للتأكيد على قراءة كل ملفات الـ src بما فيها الـ CSS
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/workers"
  ]
}